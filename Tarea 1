      "cell_type": "code",
      "source": [
        "import re\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "from urllib.request import urlopen\n",
        "\n",
        "url = \"https://raw.githubusercontent.com/RamirezArizpe/Ciencia-de-datos-para-negocios/a6e9e36b8dacd5dd3d0064af708994ba72d3f199/Consulta_20260313-231123057.csv\"\n",
        "\n",
        "# Extraer pares fecha-valor con regex\n",
        "texto = urlopen(url).read().decode(\"latin-1\").strip()\n",
        "pares = re.findall(r'(\\d{2}/\\d{2}/\\d{4}),(\\d+(?:\\.\\d+)?)', texto)\n",
        "\n",
        "# Crear DataFrame\n",
        "df = pd.DataFrame(pares, columns=[\"Fecha\", \"Rendimiento\"])\n",
        "\n",
        "# Convertir tipos\n",
        "df[\"Fecha\"] = pd.to_datetime(df[\"Fecha\"], format=\"%d/%m/%Y\")\n",
        "df[\"Rendimiento\"] = pd.to_numeric(df[\"Rendimiento\"])\n",
        "\n",
        "# Verificar\n",
        "display(df.head())\n",
        "print(f\"Número de observaciones: {len(df)}\")"
      ],
